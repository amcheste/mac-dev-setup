# Developer Environment — Secrets Template
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   cp dotfiles/secrets.template ~/.secrets
#   chmod 600 ~/.secrets
#   # Fill in your values below
#   source ~/.secrets
#
# This file is safe to commit (it contains no real credentials).
# ~/.secrets is gitignored and NEVER committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ────────────────────────────────────────────────────────────────
export ANTHROPIC_API_KEY=""

# ── Oracle Cloud (OCI) ───────────────────────────────────────────────────────
export OCIR_TOKEN=""        # Container Registry auth token
export OCIR_REGION=""       # e.g. iad, phx, lhr, fra
export OCIR_NAMESPACE=""    # Tenancy object storage namespace

# ── DigitalOcean ─────────────────────────────────────────────────────────────
export DIGITAL_OCEAN_TOKEN=""   # Personal access token (doctl)

# ── Databases ────────────────────────────────────────────────────────────────
export DB_PASSWORD=""

# ── Add any additional secrets below ─────────────────────────────────────────
