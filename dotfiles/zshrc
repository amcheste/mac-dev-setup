# ── Prompt ───────────────────────────────────────────────────────────────────
export PS1="%n:%1~ $ "

# ── Homebrew ─────────────────────────────────────────────────────────────────
eval "$(/opt/homebrew/bin/brew shellenv)" 2>/dev/null || true

# ── Java ─────────────────────────────────────────────────────────────────────
export JAVA_HOME=$(/usr/libexec/java_home 2>/dev/null)

# ── Python (pyenv) ───────────────────────────────────────────────────────────
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv &>/dev/null; then
    eval "$(pyenv init --path)"
    eval "$(pyenv init -)"
fi

# ── Node (nvm) ───────────────────────────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix 2>/dev/null)/opt/nvm/nvm.sh" ] && \
    source "$(brew --prefix)/opt/nvm/nvm.sh"
[ -s "$(brew --prefix 2>/dev/null)/opt/nvm/etc/bash_completion.d/nvm" ] && \
    source "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm"

# ── Go ───────────────────────────────────────────────────────────────────────
export GOPATH="$HOME/go"
export PATH="$GOPATH/bin:$PATH"

# ── fzf ──────────────────────────────────────────────────────────────────────
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# ── Aliases — Navigation ─────────────────────────────────────────────────────
alias repos="cd ~/Repos"
alias ll="ls -lah"
alias ..="cd .."
alias ...="cd ../.."

# ── Aliases — Kubernetes ─────────────────────────────────────────────────────
alias k="kubectl"
alias get_argo_pass="kubectl -n argocd get secret argocd-initial-admin-secret \
    -o jsonpath='{.data.password}' | base64 -d; echo"
alias argo="kubectl port-forward svc/argocd-server -n argocd 8080:443"

# ── Aliases — Terraform ──────────────────────────────────────────────────────
alias tf="terraform"

# ── Aliases — Docker ─────────────────────────────────────────────────────────
alias swagger="docker run -d -p 80:8080 swaggerapi/swagger-editor"

# ── Functions ────────────────────────────────────────────────────────────────
# Remove all stopped containers and dangling images
function docker_clean() {
    docker rm -f $(docker ps -a -q) 2>/dev/null || true
    docker rmi -f $(docker images -q) 2>/dev/null || true
}

# Make a directory and cd into it
function mkcd() {
    mkdir -p "$1" && cd "$1"
}

# ── Secrets (never commit this file) ─────────────────────────────────────────
[ -f ~/.secrets ] && source ~/.secrets

# ── Epsilon agent — GitHub App credentials ──────────────────────────────────
# See https://github.com/amcheste-ai-agent/epsilon-agent for context
export CLAUDE_GH_APP_ID="3490270"
export CLAUDE_GH_APP_PRIVATE_KEY_PATH="$HOME/.claude/secrets/amcheste-ai-agent.pem"
